# Variáveis de ambiente do banco de dados
BD_IMAGE=mysql:8.4.0
BD_PORT=3306
BD_DIR=mysql
BD_COMMAND=mysqld
MYSQL_ROOT_PASSWORD=password_root
MYSQL_DATABASE=lanchonete
MYSQL_USER=user_fiap
MYSQL_PASSWORD=password_fiap
MYSQL_ROOT_HOST=%
# Argumentos de build da aplicação
MAVEN_GROUPID_BD=com.mysql
MAVEN_ARTIFACT_BD=mysql-connector-j
MAVEN_VERSION_BD=8.4.0
# Variáveis de ambiente da aplicação
DATASOURCE_URL=jdbc:mysql://bd_lanchonete:3306/lanchonete
DATASOURCE_USERNAME=user_fiap
DATASOURCE_PASSWORD=password_fiap
DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
JPA_DIALECT=org.hibernate.dialect.MySQL8Dialect